# Telegram
BOT_TOKEN=123456:ABC-your-bot-token

# LLM provider: "openai" (any OpenAI-compatible API: DeepSeek, OpenRouter, ...) or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-key
# Base URL for OpenAI-compatible providers. For DeepSeek:
LLM_BASE_URL=https://api.deepseek.com
# For Anthropic leave LLM_BASE_URL empty (or set it to a compatible proxy) and use e.g.:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-opus-4-8

# Storage
DB_PATH=data/bot.db

# Behavior
COOLDOWN_SECONDS=120
MIN_WORDS=3
MIN_CHARS=12
CONFIDENCE_THRESHOLD=0.8
MAX_CONCURRENT_LLM=5

# Token prices (per 1M tokens) — set these to what your model actually charges.
PRICE_INPUT_PER_MILLION=0.07
PRICE_OUTPUT_PER_MILLION=0.28

# --- Wallet / billing (everything the user sees is in Toman) ---
FREE_CREDIT_TOMAN=50000
# Markup over raw API cost. 1.40 = charge 40% more than it costs us.
PRICE_MARKUP=1.40
# USD->Toman is pulled live from RATE_API_URL (USDT/Toman price on Wallex).
# This is only the fallback if that request fails.
USD_TO_TOMAN_FALLBACK=170000
RATE_API_URL=https://api.wallex.ir/v1/markets
RATE_TTL_SECONDS=600
TOPUP_PRESETS_TOMAN=50000,100000,200000

# --- Card to card (manual, admin-approved) ---
CARD_NUMBER=
CARD_HOLDER=

# --- Crypto via NOWPayments ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Public HTTPS URL NOWPayments calls back, pointing at /nowpayments/ipn
NOWPAYMENTS_IPN_URL=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8092

# Premium (custom) emoji in message text. Get IDs with the admin command /emojiid.
# Format: key:custom_emoji_id,...  Keys: wave,wallet,usage,model,settings,stats
PREMIUM_EMOJI=👋:5963288161776831684,💰:5301207025974271730,📊:5301180276917952560,💬:5301123531810037890,⚙️:5300999682133089708,💸:5960784535145680764,😎:5963091130152128477,🙏:5962913443060125576,🪙:5300848194341596510,💳:5300971309579133703,📄:5301256151810206378,📋:5301147983058854552

LOG_LEVEL=INFO
