# Telegram
BOT_TOKEN=123456:ABC-your-bot-token

# LLM provider: "openai" (any OpenAI-compatible API: DeepSeek, OpenRouter, ...) or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-key
# Base URL for OpenAI-compatible providers. For DeepSeek:
LLM_BASE_URL=https://api.deepseek.com
# For Anthropic leave LLM_BASE_URL empty (or set it to a compatible proxy) and use e.g.:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-opus-4-8

# Storage
DB_PATH=data/bot.db

# Behavior
COOLDOWN_SECONDS=120
MIN_WORDS=3
MIN_CHARS=12
CONFIDENCE_THRESHOLD=0.8
MAX_CONCURRENT_LLM=5

# Spending cap per user (USD) and token prices (per 1M tokens) for cost tracking.
# Set the prices to whatever your model actually charges so the cap is accurate.
USAGE_LIMIT_USD=0.30
PRICE_INPUT_PER_MILLION=0.07
PRICE_OUTPUT_PER_MILLION=0.28

LOG_LEVEL=INFO
